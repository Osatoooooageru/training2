<div class="field-container">

<p style="color: green"><%= notice %></p>

<p>
    <strong>投稿者:</strong>
    <%= @tweet.user.email %>
  </p>

  <p>
    <strong>トレーニング名:</strong>
    <%= @tweet.genre %>
  </p>

  <p>
    <strong>難易度:</strong>
    <%= @tweet.level %>
  </p>

  <p>
    <strong>鍛えられる部位:</strong>
    <%= @tweet.part %>
  </p>

  <p>
    <strong>器具:</strong>
    <%= @tweet.tool %>
  </p>

  <p>
    <strong>必要なスペース:</strong>
    <%= @tweet.size %>
  </p>
  
  <p>
    <strong>ジャンプ:</strong>
    <%= @tweet.jump %>
  </p>

  <p>
    <strong>メモ:</strong>
    <%= @tweet.note %>
  </p>

  
  <% if @tweet.image? %>
    <p>
      <strong>イメージ画像:</strong><br>
      <%= image_tag @tweet.image_url, width: 400 %>
    </p>
  <% end %>

  <% if @tweet.video? %>
    <p>
      <strong>動画:</strong><br>
      <%= video_tag @tweet.video.url, controls: true, width: 400 %>
    </p>
  <% end %>

  <iframe width="560" height="315" src="https://www.youtube.com/embed/<%= find_youtube_url(@tweet.youtube_url) %>" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>

<div>
  <%= link_to "編集する", edit_tweet_path(@tweet.id) %>
  <%= link_to "削除する", tweet_path(@tweet), data: { turbo_method: :delete } %>
  <%= link_to "投稿一覧に戻る",  tweets_path(anchor: "search")  %>
</div>

</div>